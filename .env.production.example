# Production environment for docker-compose.prod.yml.
# Copy to .env.production and fill in real secrets:
#   cp .env.production.example .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Generate APP_KEY once with:
#   docker compose -f docker-compose.prod.yml run --rm app php artisan key:generate --show

APP_NAME=Ticketera
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://soporte.tudominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

BCRYPT_ROUNDS=12

# Log to stderr so `docker compose logs` captures everything.
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=warning

# Database (DB_ROOT_PASSWORD is only used to initialise MariaDB).
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=ticketera
DB_USERNAME=ticketera
DB_PASSWORD=cambia-esta-clave
DB_ROOT_PASSWORD=cambia-esta-clave-root

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis

FILESYSTEM_DISK=local

# Outbound mail and inbound IMAP are configured from the admin panel (stored in DB).
MAIL_MAILER=log

# Host port nginx listens on (put a TLS-terminating proxy in front for HTTPS).
HTTP_PORT=80

# Backups (backup service)
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7
